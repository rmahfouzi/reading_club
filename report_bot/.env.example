# Copy to .env (or export these in your shell/systemd unit) before running report_bot.py

# Token for the SEPARATE report-collecting bot (not @clubKetab_bot)
REPORT_BOT_TOKEN=

# Same reading club group chat ID as the main bot — the report bot must also
# be added to this group (as a regular member) so getChatMember works.
TELEGRAM_GROUP_CHAT_ID=

# Optional overrides (default to ../daily_logs.txt and ../message_counts.json
# relative to this script, i.e. the reading_club project root)
# LOG_FILE=/path/to/reading_club/daily_logs.txt
# MSG_COUNT_FILE=/path/to/reading_club/message_counts.json
# MAX_DAILY_MESSAGES=8
