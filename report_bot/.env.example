# Copy to .env (or export these in your shell/systemd unit) before running report_bot.py

# Token for the SEPARATE report-collecting bot (not @clubKetab_bot)
REPORT_BOT_TOKEN=

# The reading club group chat ID is read from reading_db.json's
# config.group_chat_id (same source of truth as the enforcer skill) — no env
# var needed. The report bot must be added to that group (as a regular
# member) so getChatMember works.

# Optional overrides (default to ../daily_logs.txt, ../message_counts.json,
# and ../reading_db.json relative to this script, i.e. the reading_club
# project root)
# DB_FILE=/path/to/reading_club/reading_db.json
# LOG_FILE=/path/to/reading_club/daily_logs.txt
# MSG_COUNT_FILE=/path/to/reading_club/message_counts.json
# MAX_DAILY_MESSAGES=8
